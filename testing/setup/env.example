# Copy this to testing/setup/.env and fill in your values.
# All flow scripts load this file via python-dotenv.

# ============================================================
# LLM API keys — you need at least one
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...    # optional

# ============================================================
# Cloud backend (retune-cloud)
# ============================================================
# Postgres — use local Docker (default) or Supabase URL
DATABASE_URL=postgresql://retune:devpass@localhost:5432/retune

# JWT secret for signing tokens (generate one: openssl rand -hex 32)
RETUNE_JWT_SECRET=change-me-to-a-random-32-byte-hex-string

# Cloud base URL — where the SDK and frontend will hit
RETUNE_CLOUD_BASE_URL=http://localhost:8001

# ============================================================
# Test org credentials (set by 03_bootstrap_org.py)
# ============================================================
# The bootstrap script creates a test org and prints these.
# Copy them back here for subsequent scripts to use.
TEST_ORG_EMAIL=test@retune.local
TEST_ORG_PASSWORD=testpass123
TEST_ORG_NAME=Retune Test Org
RETUNE_API_KEY=rt-...     # printed by 03_bootstrap_org.py

# ============================================================
# Stripe (optional — only for premium upgrade testing)
# ============================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_TEAM_PRICE_ID=price_...
